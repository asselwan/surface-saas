---
/**
 * Draggable before/after comparison slider.
 *
 * Both halves are full live iframes — each side scrolls and is fully
 * interactable. The "before" iframe loads a static "Your Product" stale
 * 2018-style marketing landing from /demos/before.html. The "after"
 * iframe loads the URL passed in (default: nomoi.ai live).
 *
 * Drag is bound to the gold handle only so iframe pointer events
 * (scroll, hover, click) are preserved on both sides.
 */
interface Props {
  beforeUrl?: string;
  afterUrl: string;
  height?: string;
}
const {
  beforeUrl = '/demos/before.html',
  afterUrl,
  height = '640px',
} = Astro.props as Props;
---
<div
  class="surface-ba"
  data-surface-before-after
  style={`position:relative;width:100%;height:${height};border-radius:14px;overflow:hidden;border:0.5px solid var(--border-s);user-select:none`}
>
  <!-- BEFORE: full live iframe of stale marketing page -->
  <div class="surface-ba-before" style="position:absolute;inset:0;background:#fff">
    <iframe
      src={beforeUrl}
      title="A typical static landing page"
      loading="lazy"
      style="width:100%;height:100%;border:0;display:block"
    ></iframe>
  </div>

  <!--
    AFTER: live iframe, but mounted ONLY on click. Auto-mounting nomoi.ai
    inside this slider caused the box to hang the whole page while the
    embedded Astro app + Clarity + Supabase + fonts loaded (and some
    browsers/CSPs render it broken). Poster-first keeps the slider
    instant; user opts into the heavy load.
  -->
  <div class="surface-ba-after" style="position:absolute;inset:0;clip-path:inset(0 0 0 50%);background:var(--bg2)">
    <div
      data-surface-ba-poster
      style="position:absolute;inset:0;background:#0c0a08;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:14px;color:#c4976b;font-family:var(--mono);text-align:center;padding:24px"
    >
      <div style="font-size:11px;letter-spacing:0.18em;color:#6c6c66">LIVE PREVIEW · NOMOI.AI</div>
      <button
        type="button"
        data-surface-ba-activate
        style="background:var(--gold);color:#0c0a08;border:0;font-family:var(--mono);font-weight:600;font-size:13px;letter-spacing:0.06em;padding:12px 22px;border-radius:6px;cursor:pointer;box-shadow:0 4px 18px rgba(196,151,107,0.35)"
      >
        ▶ Tap to load
      </button>
      <div style="font-size:10px;letter-spacing:0.04em;color:#6c6c66;max-width:280px;line-height:1.5">
        Live page mounts inside the slider. Scroll, click, hover after it loads.
      </div>
    </div>
    <iframe
      data-surface-ba-iframe
      data-src={afterUrl}
      src="about:blank"
      title="A live Surface page — move your cursor, scroll"
      loading="lazy"
      style="width:100%;height:100%;border:0;display:none;background:#0c0a08"
    ></iframe>
  </div>

  <!-- Labels (pointer-events:none so they don't block the iframes) -->
  <div style="position:absolute;top:14px;left:14px;font-family:var(--mono);font-size:10px;letter-spacing:0.16em;color:#6c6c66;background:rgba(255,255,255,0.92);padding:6px 10px;border-radius:4px;pointer-events:none;z-index:4">
    BEFORE
  </div>
  <div style="position:absolute;top:14px;right:14px;font-family:var(--mono);font-size:10px;letter-spacing:0.16em;color:#0c0a08;background:var(--gold);padding:6px 10px;border-radius:4px;pointer-events:none;z-index:4">
    AFTER · LIVE
  </div>

  <!-- Divider + draggable handle. ONLY the handle captures pointer events. -->
  <div class="surface-ba-divider" style="position:absolute;top:0;bottom:0;left:50%;width:2px;background:var(--gold);transform:translateX(-50%);pointer-events:none;z-index:5;box-shadow:0 0 12px rgba(196,151,107,0.6)">
    <div
      class="surface-ba-handle"
      role="slider"
      aria-label="Drag to compare"
      style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:52px;height:52px;border-radius:50%;background:var(--gold);box-shadow:0 4px 20px rgba(0,0,0,0.5);display:flex;align-items:center;justify-content:center;color:#0c0a08;font-family:var(--mono);font-weight:600;font-size:12px;letter-spacing:0.06em;cursor:ew-resize;pointer-events:auto;touch-action:none"
    >
      ◂ ▸
    </div>
  </div>
</div>

<p style="font-family:var(--mono);font-size:11px;color:var(--text-faint);margin:14px 0 0;text-align:center;letter-spacing:0.04em">
  Drag the gold handle to compare. Scroll inside either side. Move your cursor on the right — that's nomoi.ai live.
</p>

<script is:inline>
  (function () {
    const wraps = document.querySelectorAll('[data-surface-before-after]');
    wraps.forEach((wrap) => {
      const after = wrap.querySelector('.surface-ba-after');
      const divider = wrap.querySelector('.surface-ba-divider');
      const handle = wrap.querySelector('.surface-ba-handle');
      if (!after || !divider || !handle) return;

      // Click-to-activate live iframe (poster -> iframe swap).
      const poster = wrap.querySelector('[data-surface-ba-poster]');
      const liveFrame = wrap.querySelector('[data-surface-ba-iframe]');
      const activate = wrap.querySelector('[data-surface-ba-activate]');
      if (activate && poster && liveFrame) {
        activate.addEventListener('click', (ev) => {
          ev.preventDefault();
          ev.stopPropagation();
          const src = liveFrame.getAttribute('data-src');
          if (src) liveFrame.setAttribute('src', src);
          liveFrame.style.display = 'block';
          poster.style.display = 'none';
        });
      }

      let dragging = false;

      const setPosition = (clientX) => {
        const rect = wrap.getBoundingClientRect();
        const x = Math.max(0, Math.min(rect.width, clientX - rect.left));
        const pct = (x / rect.width) * 100;
        after.style.clipPath = `inset(0 0 0 ${pct}%)`;
        divider.style.left = `${pct}%`;
      };

      const onDown = (ev) => {
        dragging = true;
        const x = ev.touches ? ev.touches[0].clientX : ev.clientX;
        setPosition(x);
        ev.preventDefault();
        ev.stopPropagation();
      };
      const onMove = (ev) => {
        if (!dragging) return;
        const x = ev.touches ? ev.touches[0].clientX : ev.clientX;
        setPosition(x);
        ev.preventDefault();
      };
      const onUp = () => { dragging = false; };

      // Drag ONLY from the handle so iframes keep natural pointer + scroll events.
      handle.addEventListener('mousedown', onDown);
      handle.addEventListener('touchstart', onDown, { passive: false });
      window.addEventListener('mousemove', onMove, { passive: false });
      window.addEventListener('touchmove', onMove, { passive: false });
      window.addEventListener('mouseup', onUp);
      window.addEventListener('touchend', onUp);

      // Auto-wiggle on first viewport entry so the affordance is obvious.
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (!e.isIntersecting) return;
          io.disconnect();
          let pct = 50;
          let dir = -1;
          let step = 0;
          const tick = () => {
            pct += dir * 1.5;
            if (pct <= 22) dir = 1;
            if (pct >= 78) dir = -1;
            after.style.clipPath = `inset(0 0 0 ${pct}%)`;
            divider.style.left = `${pct}%`;
            step += 1;
            if (step < 90 && !dragging) requestAnimationFrame(tick);
            else if (!dragging) {
              after.style.transition = 'clip-path 0.5s';
              divider.style.transition = 'left 0.5s';
              after.style.clipPath = 'inset(0 0 0 50%)';
              divider.style.left = '50%';
              setTimeout(() => {
                after.style.transition = '';
                divider.style.transition = '';
              }, 600);
            }
          };
          requestAnimationFrame(tick);
        });
      }, { threshold: 0.3 });
      io.observe(wrap);
    });
  })();
</script>
