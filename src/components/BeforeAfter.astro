---
/**
 * Draggable before/after comparison slider.
 *
 * "Before" is an inline HTML mockup of a typical stale landing page.
 * "After" is a LIVE iframe of nomoi.ai (or any URL passed in). The cursor
 * moves naturally over the after-half and the embedded page's own motion
 * (ambient, signature, cursor-following hover) responds in real time.
 *
 * Drag is bound to the gold handle ONLY so iframe pointer events are
 * preserved. The handle auto-wiggles once on first viewport entry so the
 * affordance is obvious.
 *
 * Accepts a video URL OR a webpage URL via afterUrl. .mp4/.webm renders
 * a <video>; anything else renders an <iframe>.
 */
interface Props {
  afterUrl: string;
  posterAfter?: string;
  beforeName?: string;
  beforeTagline?: string;
}
const {
  afterUrl,
  posterAfter,
  beforeName = 'Your Product',
  beforeTagline = 'The leading platform for modern teams. Get started today and unlock your potential.',
} = Astro.props as Props;

const isVideo = /\.(mp4|webm|mov)(\?|$)/i.test(afterUrl);
---
<div
  class="surface-ba"
  data-surface-before-after
  style="position:relative;width:100%;aspect-ratio:16/9;border-radius:14px;overflow:hidden;border:0.5px solid var(--border-s);user-select:none;touch-action:pan-y"
>
  <!-- BEFORE: inline HTML mockup of a flat, lifeless landing page -->
  <div style="position:absolute;inset:0;background:#f6f6f4;color:#1e1e1e;font-family:'Inter',system-ui,sans-serif;display:flex;flex-direction:column;pointer-events:none">
    <div style="display:flex;align-items:center;justify-content:space-between;padding:18px 32px;border-bottom:1px solid #e5e5e0">
      <div style="font-weight:700;font-size:15px;letter-spacing:-0.01em">{beforeName.toUpperCase()}</div>
      <div style="display:flex;gap:22px;font-size:12px;color:#6c6c66">
        <span>Product</span><span>Pricing</span><span>Login</span>
      </div>
    </div>
    <div style="flex:1;display:flex;flex-direction:column;justify-content:center;padding:0 8% 0 8%;gap:14px">
      <div style="font-size:11px;letter-spacing:0.18em;color:#9c9c95;font-weight:500">TRUSTED BY TEAMS WORLDWIDE</div>
      <h3 style="font-size:42px;font-weight:600;line-height:1.05;letter-spacing:-0.02em;color:#101010;margin:0;max-width:80%">
        {beforeName}: built for the way you work.
      </h3>
      <p style="font-size:14px;line-height:1.55;color:#5b5b54;max-width:60%;margin:0">{beforeTagline}</p>
      <div style="display:flex;gap:10px;margin-top:10px">
        <span style="background:#1e1e1e;color:#fff;padding:11px 22px;border-radius:6px;font-size:12px;font-weight:500">Get started</span>
        <span style="background:#fff;color:#1e1e1e;padding:11px 22px;border-radius:6px;font-size:12px;border:1px solid #d8d8d2">Learn more</span>
      </div>
    </div>
    <div style="display:flex;gap:10px;padding:0 8% 22px">
      <div style="flex:1;height:34px;background:#ececec;border-radius:4px"></div>
      <div style="flex:1;height:34px;background:#ececec;border-radius:4px"></div>
      <div style="flex:1;height:34px;background:#ececec;border-radius:4px"></div>
    </div>
  </div>

  <!-- AFTER: live iframe of nomoi.ai (or video if asset URL) -->
  <div class="surface-ba-after" style="position:absolute;inset:0;clip-path:inset(0 0 0 50%);background:var(--bg2)">
    {isVideo ? (
      <video autoplay muted playsinline loop preload="metadata" poster={posterAfter} aria-label="Live Surface page"
        style="width:100%;height:100%;object-fit:cover;display:block">
        <source src={afterUrl} type="video/mp4" />
      </video>
    ) : (
      <iframe
        src={afterUrl}
        title="A live Surface page — move your cursor"
        loading="lazy"
        scrolling="no"
        style="width:1600px;height:900px;border:0;display:block;transform-origin:top left;transform:scale(0.675);pointer-events:auto;background:#0c0a08"
      ></iframe>
    )}
  </div>

  <!-- Labels (pointer-events:none so they don't block the iframe) -->
  <div style="position:absolute;top:14px;left:14px;font-family:var(--mono);font-size:10px;letter-spacing:0.16em;color:#6c6c66;background:rgba(255,255,255,0.85);padding:6px 10px;border-radius:4px;pointer-events:none;z-index:4">
    BEFORE
  </div>
  <div style="position:absolute;top:14px;right:14px;font-family:var(--mono);font-size:10px;letter-spacing:0.16em;color:#0c0a08;background:var(--gold);padding:6px 10px;border-radius:4px;pointer-events:none;z-index:4">
    AFTER · LIVE
  </div>

  <!-- Divider + draggable handle. ONLY the handle captures pointer events. -->
  <div class="surface-ba-divider" style="position:absolute;top:0;bottom:0;left:50%;width:2px;background:var(--gold);transform:translateX(-50%);pointer-events:none;z-index:5">
    <div
      class="surface-ba-handle"
      role="slider"
      aria-label="Drag to compare"
      style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:48px;height:48px;border-radius:50%;background:var(--gold);box-shadow:0 4px 16px rgba(0,0,0,0.4);display:flex;align-items:center;justify-content:center;color:#0c0a08;font-family:var(--mono);font-weight:600;font-size:11px;letter-spacing:0.06em;cursor:ew-resize;pointer-events:auto;touch-action:none"
    >
      ◂ ▸
    </div>
  </div>
</div>

<p style="font-family:var(--mono);font-size:11px;color:var(--text-faint);margin:14px 0 0;text-align:center;letter-spacing:0.04em">
  Drag the gold handle. Move your cursor on the right side — that's nomoi.ai live, reacting to you.
</p>

<script is:inline>
  (function () {
    const wraps = document.querySelectorAll('[data-surface-before-after]');
    wraps.forEach((wrap) => {
      const after = wrap.querySelector('.surface-ba-after');
      const divider = wrap.querySelector('.surface-ba-divider');
      const handle = wrap.querySelector('.surface-ba-handle');
      if (!after || !divider || !handle) return;
      let dragging = false;

      const setPosition = (clientX) => {
        const rect = wrap.getBoundingClientRect();
        const x = Math.max(0, Math.min(rect.width, clientX - rect.left));
        const pct = (x / rect.width) * 100;
        after.style.clipPath = `inset(0 0 0 ${pct}%)`;
        divider.style.left = `${pct}%`;
      };

      const onDown = (ev) => {
        dragging = true;
        const x = ev.touches ? ev.touches[0].clientX : ev.clientX;
        setPosition(x);
        ev.preventDefault();
        ev.stopPropagation();
      };
      const onMove = (ev) => {
        if (!dragging) return;
        const x = ev.touches ? ev.touches[0].clientX : ev.clientX;
        setPosition(x);
        ev.preventDefault();
      };
      const onUp = () => { dragging = false; };

      // Drag ONLY from the handle so the iframe keeps natural pointer events.
      handle.addEventListener('mousedown', onDown);
      handle.addEventListener('touchstart', onDown, { passive: false });
      window.addEventListener('mousemove', onMove, { passive: false });
      window.addEventListener('touchmove', onMove, { passive: false });
      window.addEventListener('mouseup', onUp);
      window.addEventListener('touchend', onUp);

      // Auto-wiggle on first viewport entry so the affordance is obvious.
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (!e.isIntersecting) return;
          io.disconnect();
          let pct = 50;
          let dir = -1;
          let step = 0;
          const tick = () => {
            pct += dir * 1.5;
            if (pct <= 22) dir = 1;
            if (pct >= 78) dir = -1;
            after.style.clipPath = `inset(0 0 0 ${pct}%)`;
            divider.style.left = `${pct}%`;
            step += 1;
            if (step < 90 && !dragging) requestAnimationFrame(tick);
            else if (!dragging) {
              after.style.transition = 'clip-path 0.5s';
              divider.style.transition = 'left 0.5s';
              after.style.clipPath = 'inset(0 0 0 50%)';
              divider.style.left = '50%';
              setTimeout(() => {
                after.style.transition = '';
                divider.style.transition = '';
              }, 600);
            }
          };
          requestAnimationFrame(tick);
        });
      }, { threshold: 0.3 });
      io.observe(wrap);
    });
  })();
</script>
