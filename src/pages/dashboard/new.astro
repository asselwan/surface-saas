---
import Brand from '@/components/Brand.astro';
import { getSession } from '@/lib/auth';
import { createProduct, listProducts } from '@/lib/products';
import { gateAddProduct, getPlan } from '@/lib/plans';
import { scrapeUrl, deriveKey, type ScrapeResult } from '@/lib/scrape';

export const prerender = false;
const session = await getSession(Astro.cookies);
if (!session) return Astro.redirect('/login');
if (!session.account) return Astro.redirect('/dashboard');

const existingProducts = await listProducts(Astro.cookies);
const plan = getPlan(session.account.plan);
const gate = gateAddProduct(plan, existingProducts.length);

let error: string | null = gate.allowed ? null : gate.reason;
let scrape: ScrapeResult | null = null;
let formUrl = '';

if (Astro.request.method === 'POST' && gate.allowed) {
  const form = await Astro.request.formData();
  const stage = String(form.get('_stage') ?? 'scrape');
  formUrl = String(form.get('url') ?? '').trim();

  if (!formUrl) {
    error = 'Paste your URL.';
  } else if (stage === 'scrape') {
    scrape = await scrapeUrl(formUrl);
  } else if (stage === 'confirm') {
    const key = String(form.get('key') ?? deriveKey(formUrl)).toLowerCase().slice(0, 40);
    const name = String(form.get('name') ?? '').trim() || formUrl.replace(/^https?:\/\//, '').replace(/\/$/, '').slice(0, 120);
    const tagline = String(form.get('tagline') ?? '').trim();
    const essay = String(form.get('essay') ?? '').trim();
    const cta = String(form.get('cta') ?? '').trim();
    const category = String(form.get('category') ?? '').trim();
    const pricing = String(form.get('pricing') ?? '').trim();

    if (!/^[a-z0-9-]{2,40}$/.test(key)) {
      error = 'Key must be 2-40 chars, lowercase letters / digits / hyphens.';
    } else {
      const result = await createProduct(Astro.cookies, {
        key, name, tagline, essay, url: formUrl, cta, category, pricing,
      });
      if ('id' in result) {
        return Astro.redirect(`/dashboard/products/${result.id}?added=1`);
      }
      error = result.error;
    }
  }
}

const showStage = scrape ? 'confirm' : 'url';
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Add a product — NOMOI Surface</title>
</head>
<body>
<Brand authedEmail={session.user.email} />

<main style="max-width:680px;margin:0 auto;padding:48px 36px 80px">
  <p style="font-family:var(--mono);font-size:11px;letter-spacing:0.16em;color:var(--gold);margin:0 0 14px">
    <a href="/dashboard" style="text-decoration:none;color:inherit">DASHBOARD</a> · NEW PRODUCT
  </p>

  {showStage === 'url' ? (
    <>
      <h1 style="font-family:var(--serif);font-size:38px;font-weight:400;line-height:1.05;margin:0 0 14px">Paste your URL. We read the rest.</h1>
      <p style="font-family:var(--sans);font-size:15px;color:var(--text-mid);font-weight:300;margin:0 0 32px;line-height:1.6">
        Drop the homepage. We'll fetch the title, description, and a working draft of everything else. You confirm in twenty seconds.
      </p>

      {error && (
        <p style="background:rgba(196,151,107,0.12);border:0.5px solid var(--gold);border-radius:8px;padding:12px 18px;font-family:var(--mono);font-size:12px;color:var(--gold);margin:0 0 24px">
          {error}
        </p>
      )}

      <form method="post" style="display:grid;gap:14px">
        <input type="hidden" name="_stage" value="scrape" />
        <label style="display:grid;gap:8px">
          <span style="font-family:var(--mono);font-size:11px;letter-spacing:0.12em;color:var(--text-mid)">URL</span>
          <input name="url" type="url" required autofocus value={formUrl} placeholder="https://yourproduct.com"
            style="font-family:var(--mono);font-size:16px;background:var(--bg2);border:0.5px solid var(--border-s);border-radius:10px;padding:16px 20px;color:var(--text)" />
        </label>
        <div style="display:flex;gap:12px;margin-top:6px">
          <button type="submit" style="background:var(--gold);color:#0c0a08;padding:14px 28px;border-radius:8px;border:none;font-family:var(--mono);font-size:13px;font-weight:500;cursor:pointer">
            Read it →
          </button>
          <a href="/dashboard" style="padding:14px 18px;border-radius:8px;font-family:var(--mono);font-size:13px;color:var(--text-muted);text-decoration:none">
            Cancel
          </a>
        </div>
      </form>

      <details style="margin-top:36px">
        <summary style="font-family:var(--mono);font-size:11px;color:var(--text-faint);cursor:pointer;letter-spacing:0.04em">No URL yet? Enter everything by hand</summary>
        <p style="font-family:var(--sans);font-size:13px;color:var(--text-muted);margin:14px 0 0;line-height:1.6">
          Pre-launch products work too. Paste a placeholder URL like <code style="font-family:var(--mono);color:var(--text)">https://yourname.example</code> and fill in the rest on the confirmation page.
        </p>
      </details>
    </>
  ) : (
    <>
      <h1 style="font-family:var(--serif);font-size:34px;font-weight:400;line-height:1.05;margin:0 0 14px">Here's what we found.</h1>
      <p style="font-family:var(--sans);font-size:14px;color:var(--text-mid);font-weight:300;margin:0 0 28px;line-height:1.6">
        We read <span style="color:var(--gold);font-family:var(--mono);font-size:13px">{scrape!.hostname}</span>. Edit anything that's off, then save. First refresh runs about ten minutes after.
      </p>

      {scrape!.error && !scrape!.name && (
        <p style="background:rgba(196,151,107,0.12);border:0.5px solid var(--gold);border-radius:8px;padding:12px 18px;font-family:var(--mono);font-size:12px;color:var(--gold);margin:0 0 18px">
          We could not read that page ({scrape!.error}). Fill in the fields below and save anyway — Surface will work from what you give us.
        </p>
      )}
      {error && (
        <p style="background:rgba(196,151,107,0.12);border:0.5px solid var(--gold);border-radius:8px;padding:12px 18px;font-family:var(--mono);font-size:12px;color:var(--gold);margin:0 0 18px">
          {error}
        </p>
      )}

      <form method="post" style="display:grid;gap:18px">
        <input type="hidden" name="_stage" value="confirm" />
        <input type="hidden" name="url" value={scrape!.url} />

        <label style="display:grid;gap:6px">
          <span style="font-family:var(--mono);font-size:11px;letter-spacing:0.12em;color:var(--text-mid)">KEY</span>
          <input name="key" required value={scrape!.derivedKey} pattern="[a-z0-9-]{2,40}"
            style="font-family:var(--mono);font-size:13px;background:var(--bg2);border:0.5px solid var(--border-s);border-radius:8px;padding:12px 14px;color:var(--text)" />
          <span style="font-family:var(--mono);font-size:10px;color:var(--text-faint)">URL-safe slug, derived from your hostname. Edit if you want.</span>
        </label>

        <label style="display:grid;gap:6px">
          <span style="font-family:var(--mono);font-size:11px;letter-spacing:0.12em;color:var(--text-mid)">NAME</span>
          <input name="name" required value={scrape!.name ?? ''}
            style="font-family:var(--serif);font-size:18px;background:var(--bg2);border:0.5px solid var(--border-s);border-radius:8px;padding:12px 14px;color:var(--text)" />
        </label>

        <label style="display:grid;gap:6px">
          <span style="font-family:var(--mono);font-size:11px;letter-spacing:0.12em;color:var(--text-mid)">TAGLINE</span>
          <input name="tagline" value={scrape!.tagline ?? ''} maxlength="200" placeholder="One short sentence."
            style="font-family:var(--sans);font-size:14px;background:var(--bg2);border:0.5px solid var(--border-s);border-radius:8px;padding:12px 14px;color:var(--text)" />
        </label>

        <label style="display:grid;gap:6px">
          <span style="font-family:var(--mono);font-size:11px;letter-spacing:0.12em;color:var(--text-mid)">ESSAY</span>
          <textarea name="essay" rows="4" maxlength="1500"
            style="font-family:var(--sans);font-size:14px;background:var(--bg2);border:0.5px solid var(--border-s);border-radius:8px;padding:12px 14px;color:var(--text);resize:vertical">{scrape!.essay ?? ''}</textarea>
        </label>

        <details>
          <summary style="font-family:var(--mono);font-size:11px;color:var(--text-faint);cursor:pointer;letter-spacing:0.04em">Optional: CTA, category, pricing</summary>
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin-top:14px">
            <label style="display:grid;gap:6px">
              <span style="font-family:var(--mono);font-size:11px;letter-spacing:0.12em;color:var(--text-mid)">CTA</span>
              <input name="cta" maxlength="40"
                style="font-family:var(--mono);font-size:13px;background:var(--bg2);border:0.5px solid var(--border-s);border-radius:8px;padding:10px 12px;color:var(--text)" />
            </label>
            <label style="display:grid;gap:6px">
              <span style="font-family:var(--mono);font-size:11px;letter-spacing:0.12em;color:var(--text-mid)">CATEGORY</span>
              <input name="category"
                style="font-family:var(--mono);font-size:13px;background:var(--bg2);border:0.5px solid var(--border-s);border-radius:8px;padding:10px 12px;color:var(--text)" />
            </label>
            <label style="display:grid;gap:6px">
              <span style="font-family:var(--mono);font-size:11px;letter-spacing:0.12em;color:var(--text-mid)">PRICING</span>
              <input name="pricing"
                style="font-family:var(--mono);font-size:13px;background:var(--bg2);border:0.5px solid var(--border-s);border-radius:8px;padding:10px 12px;color:var(--text)" />
            </label>
          </div>
        </details>

        <div style="display:flex;gap:12px;margin-top:6px">
          <button type="submit" style="background:var(--gold);color:#0c0a08;padding:14px 28px;border-radius:8px;border:none;font-family:var(--mono);font-size:13px;font-weight:500;cursor:pointer">
            Save and start →
          </button>
          <a href="/dashboard/new" style="padding:14px 18px;border-radius:8px;font-family:var(--mono);font-size:13px;color:var(--text-muted);text-decoration:none">
            Different URL
          </a>
        </div>
      </form>
    </>
  )}
</main>
</body>
</html>
