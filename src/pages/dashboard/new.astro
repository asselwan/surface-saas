---
import Brand from '@/components/Brand.astro';
import { getSession } from '@/lib/auth';
import { createProduct, listProducts } from '@/lib/products';
import { gateAddProduct, getPlan } from '@/lib/plans';

export const prerender = false;
const session = await getSession(Astro.cookies);
if (!session) return Astro.redirect('/login');
if (!session.account) return Astro.redirect('/dashboard');

const existingProducts = await listProducts(Astro.cookies);
const plan = getPlan(session.account.plan);
const gate = gateAddProduct(plan, existingProducts.length);

let error: string | null = gate.allowed ? null : gate.reason;
let formValues = { key: '', name: '', tagline: '', essay: '', url: '', cta: '', category: '', pricing: '' };

if (Astro.request.method === 'POST' && gate.allowed) {
  const form = await Astro.request.formData();
  const key = String(form.get('key') ?? '').trim().toLowerCase();
  const name = String(form.get('name') ?? '').trim();
  const tagline = String(form.get('tagline') ?? '').trim();
  const essay = String(form.get('essay') ?? '').trim();
  const url = String(form.get('url') ?? '').trim();
  const cta = String(form.get('cta') ?? '').trim();
  const category = String(form.get('category') ?? '').trim();
  const pricing = String(form.get('pricing') ?? '').trim();
  formValues = { key, name, tagline, essay, url, cta, category, pricing };

  if (!/^[a-z0-9-]{2,40}$/.test(key)) {
    error = 'Key must be 2-40 chars, lowercase letters / digits / hyphens.';
  } else if (!name) {
    error = 'Name is required.';
  } else {
    const result = await createProduct(Astro.cookies, {
      key, name, tagline, essay, url, cta, category, pricing,
    });
    if ('id' in result) {
      return Astro.redirect(`/dashboard/products/${result.id}?added=1`);
    }
    error = result.error;
  }
}
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Add a product — NOMOI Surface</title>
</head>
<body>
<Brand authedEmail={session.user.email} />

<main style="max-width:680px;margin:0 auto;padding:48px 36px 80px">
  <p style="font-family:var(--mono);font-size:11px;letter-spacing:0.16em;color:var(--gold);margin:0 0 14px">
    <a href="/dashboard" style="text-decoration:none;color:inherit">DASHBOARD</a> · NEW PRODUCT
  </p>
  <h1 style="font-family:var(--serif);font-size:38px;font-weight:400;line-height:1.1;margin:0 0 14px">Add a product</h1>
  <p style="font-family:var(--sans);font-size:14px;color:var(--text-mid);font-weight:300;margin:0 0 36px">
    Fill what you know. Surface starts working from whatever you give it. First refresh runs about ten minutes after you save.
  </p>

  {error && (
    <p style="background:rgba(196,151,107,0.12);border:0.5px solid var(--gold);border-radius:8px;padding:14px 18px;font-family:var(--mono);font-size:12px;color:var(--gold);margin:0 0 24px">
      {error}
    </p>
  )}

  <form method="post" style="display:grid;gap:20px">
    <label style="display:grid;gap:6px">
      <span style="font-family:var(--mono);font-size:11px;letter-spacing:0.12em;color:var(--text-mid)">KEY</span>
      <input name="key" required value={formValues.key} placeholder="cogwellness" pattern="[a-z0-9-]{2,40}"
        style="font-family:var(--mono);font-size:13px;background:var(--bg2);border:0.5px solid var(--border-s);border-radius:8px;padding:12px 14px;color:var(--text)" />
      <span style="font-family:var(--mono);font-size:10px;color:var(--text-faint)">URL-safe identifier. Becomes the storage key. Cannot be changed later.</span>
    </label>

    <label style="display:grid;gap:6px">
      <span style="font-family:var(--mono);font-size:11px;letter-spacing:0.12em;color:var(--text-mid)">NAME</span>
      <input name="name" required value={formValues.name} placeholder="Cognitive Wellness"
        style="font-family:var(--serif);font-size:18px;background:var(--bg2);border:0.5px solid var(--border-s);border-radius:8px;padding:12px 14px;color:var(--text)" />
    </label>

    <label style="display:grid;gap:6px">
      <span style="font-family:var(--mono);font-size:11px;letter-spacing:0.12em;color:var(--text-mid)">TAGLINE</span>
      <input name="tagline" value={formValues.tagline} maxlength="200" placeholder="One short sentence."
        style="font-family:var(--sans);font-size:14px;background:var(--bg2);border:0.5px solid var(--border-s);border-radius:8px;padding:12px 14px;color:var(--text)" />
    </label>

    <label style="display:grid;gap:6px">
      <span style="font-family:var(--mono);font-size:11px;letter-spacing:0.12em;color:var(--text-mid)">ESSAY</span>
      <textarea name="essay" maxlength="2000" rows="5" placeholder="Two to four sentences. What the product does, who it serves."
        style="font-family:var(--sans);font-size:14px;background:var(--bg2);border:0.5px solid var(--border-s);border-radius:8px;padding:12px 14px;color:var(--text);resize:vertical">{formValues.essay}</textarea>
    </label>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px">
      <label style="display:grid;gap:6px">
        <span style="font-family:var(--mono);font-size:11px;letter-spacing:0.12em;color:var(--text-mid)">URL</span>
        <input name="url" value={formValues.url} placeholder="snapshot.nomoi.ai"
          style="font-family:var(--mono);font-size:13px;background:var(--bg2);border:0.5px solid var(--border-s);border-radius:8px;padding:12px 14px;color:var(--text)" />
      </label>
      <label style="display:grid;gap:6px">
        <span style="font-family:var(--mono);font-size:11px;letter-spacing:0.12em;color:var(--text-mid)">CTA</span>
        <input name="cta" value={formValues.cta} maxlength="40" placeholder="Start an intake"
          style="font-family:var(--mono);font-size:13px;background:var(--bg2);border:0.5px solid var(--border-s);border-radius:8px;padding:12px 14px;color:var(--text)" />
      </label>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px">
      <label style="display:grid;gap:6px">
        <span style="font-family:var(--mono);font-size:11px;letter-spacing:0.12em;color:var(--text-mid)">CATEGORY</span>
        <input name="category" value={formValues.category} placeholder="health"
          style="font-family:var(--mono);font-size:13px;background:var(--bg2);border:0.5px solid var(--border-s);border-radius:8px;padding:12px 14px;color:var(--text)" />
      </label>
      <label style="display:grid;gap:6px">
        <span style="font-family:var(--mono);font-size:11px;letter-spacing:0.12em;color:var(--text-mid)">PRICING</span>
        <input name="pricing" value={formValues.pricing} placeholder="AED 500 per report"
          style="font-family:var(--mono);font-size:13px;background:var(--bg2);border:0.5px solid var(--border-s);border-radius:8px;padding:12px 14px;color:var(--text)" />
      </label>
    </div>

    <div style="display:flex;gap:12px;margin-top:8px">
      <button type="submit" style="background:var(--gold);color:#0c0a08;padding:12px 28px;border-radius:8px;border:none;font-family:var(--mono);font-size:13px;font-weight:500;cursor:pointer">
        Add product →
      </button>
      <a href="/dashboard" style="padding:12px 18px;border-radius:8px;font-family:var(--mono);font-size:13px;color:var(--text-muted);text-decoration:none">
        Cancel
      </a>
    </div>
  </form>
</main>
</body>
</html>
