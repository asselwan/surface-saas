---
import { setSessionCookie, ensureAccount } from '@/lib/auth';
import { getServerClient } from '@/lib/supabase';
import { createProduct } from '@/lib/products';
import { deriveKey } from '@/lib/scrape';

export const prerender = false;

const PENDING_COOKIE = 'surface-pending-intent';

const url = Astro.url;
const queryToken = url.searchParams.get('token');

if (queryToken) {
  const client = getServerClient(Astro.cookies);
  const { data, error } = await client.auth.getUser(queryToken);
  if (!error && data.user) {
    setSessionCookie(Astro.cookies, queryToken);
    try {
      await ensureAccount(Astro.cookies, { id: data.user.id, email: data.user.email ?? '' });
    } catch (err) {
      console.error('[auth/callback] account bootstrap failed', err);
    }

    // If the user came in via /start with a pre-scraped product, create it now
    // so the dashboard isn't empty on first visit.
    const pendingRaw = Astro.cookies.get(PENDING_COOKIE)?.value;
    let redirectTarget = '/dashboard';
    if (pendingRaw) {
      try {
        const pending = JSON.parse(pendingRaw) as {
          url?: string;
          derivedKey?: string;
          name?: string | null;
          tagline?: string | null;
          essay?: string | null;
        };
        if (pending.url) {
          const key = (pending.derivedKey || deriveKey(pending.url)).toLowerCase();
          const name = pending.name || pending.url.replace(/^https?:\/\//, '').replace(/\/$/, '');
          const result = await createProduct(Astro.cookies, {
            key,
            name: name.slice(0, 120),
            tagline: pending.tagline?.slice(0, 200) || undefined,
            essay: pending.essay?.slice(0, 1200) || undefined,
            url: pending.url,
          });
          if ('id' in result) {
            redirectTarget = `/dashboard/products/${result.id}?added=1&fromStart=1`;
          }
        }
      } catch (err) {
        console.error('[auth/callback] pending intent parse failed', err);
      }
      Astro.cookies.delete(PENDING_COOKIE, { path: '/' });
    }
    return Astro.redirect(redirectTarget);
  }
  return Astro.redirect('/login?error=invalid_token');
}
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<title>Signing you in…</title>
<style>
  body { background:#0c0a08; color:#f4f1ea; font-family:"IBM Plex Mono",monospace; display:flex; align-items:center; justify-content:center; min-height:100vh; margin:0 }
</style>
</head>
<body>
<div>Signing you in…</div>
<script is:inline>
  // Supabase puts the access_token in URL fragment. Pull it out and
  // re-hit this page with the token as a query param so the SSR leg
  // can validate + cookie-set.
  (function() {
    const hash = window.location.hash.slice(1);
    const params = new URLSearchParams(hash);
    const token = params.get('access_token');
    if (token) {
      const next = `${window.location.pathname}?token=${encodeURIComponent(token)}`;
      window.location.replace(next);
    } else {
      window.location.replace('/login?error=no_token');
    }
  })();
</script>
</body>
</html>
